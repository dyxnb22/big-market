        <mxCell id="ST-job" value="UpdateAwardStockJob  (XXL-Job, every minute)&#xa;Drain delay-queue → batch update MySQL"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E74C3C;
                       strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=10;fontStyle=1;"
                vertex="1" parent="1">
          <mxGeometry x="200" y="3380" width="420" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a-st-queue-job" style="endArrow=block;endFill=1;"
                edge="1" parent="1" source="ST-queue" target="ST-job">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ST-mysql-chk" value="MySQL update OK?"
                style="rhombus;whiteSpace=wrap;html=1;fillColor=#F39C12;
                       strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;fontStyle=1;"
                vertex="1" parent="1">

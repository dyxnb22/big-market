<?xml version="1.0" encoding="UTF-8"?>
<!--
  Big-Market Marketing Raffle System — Complete Business Flow Diagram
  大市场营销抽奖系统 — 完整业务流程图

  How to open:
    1. Go to https://app.diagrams.net  (draw.io)
    2. File > Open From > Device, select this file
    OR
    3. Drag-and-drop this file into the draw.io browser window

  Diagram panels:
    Panel 1 (top)    — System Architecture Layers
    Panel 2          — Complete Raffle Main Flow
    Panel 3          — Behavior Rebate Flow + Strategy/Activity Armory Flow
    Panel 4 (bottom) — Stock Eventual Consistency + DB Sharding Architecture
-->
<mxfile host="app.diagrams.net" modified="2026-03-11" version="21.6.5">
  <diagram name="Big-Market Business Flow" id="big-market-flow">

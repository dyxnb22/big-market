                edge="1" parent="1" source="ST-job" target="ST-mysql-chk">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ST-dlq" value="MQ dead-letter queue&#xa;fallback retry"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E74C3C;

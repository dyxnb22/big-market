          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ST-ok" value="MySQL strategy_award.stock synced  [OK]"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#27AE60;
                       strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;fontStyle=1;"
                vertex="1" parent="1">
          <mxGeometry x="200" y="3558" width="420" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="a-st-chk-ok" value="OK" style="endArrow=block;endFill=1;"
                edge="1" parent="1" source="ST-mysql-chk" target="ST-ok">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ST-zero" value="When Redis stock = 0&#xa;→ Emit ActivitySkuStockZeroMessageEvent&#xa;→ ActivitySkuStockZeroCustomer consumes&#xa;→ Set raffle_activity_sku.stock_count_surplus = 0  (delist)"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9B59B6;
                       strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=10;"
                vertex="1" parent="1">
          <mxGeometry x="200" y="3628" width="420" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="a-st-ok-zero" style="endArrow=block;endFill=1;"
                edge="1" parent="1" source="ST-ok" target="ST-zero">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ST-comp" value="SendMessageTaskJob  (compensation, every minute)&#xa;Scan task table status=create&#xa;Re-publish pending MQ messages  (at-least-once guarantee)"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E74C3C;
                       strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=10;fontStyle=1;"
                vertex="1" parent="1">
